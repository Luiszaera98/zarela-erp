# ============================================================
# Zarela ERP — Variables de Entorno
# ============================================================
# Copia este archivo como .env.local y llena los valores.
# NUNCA subas .env.local a Git.
# ============================================================

# === Base de Datos ===
# Docker: mongodb://admin:password@mongodb:27017/zarela_erp?authSource=admin
# Local:  mongodb://localhost:27017/zarela_erp
MONGODB_URI=mongodb://localhost:27017/zarela_erp

# Credenciales Docker (solo si usas docker-compose)
DB_USER=admin
DB_PASSWORD=change_this_to_a_secure_password

# === Next.js ===
# En producción, pon tu dominio real (ej: https://erp.zarela.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000
JWT_SECRET=

# ============================================================
# === e-CF DGII (Facturación Electrónica) ====================
# ============================================================

# Ambiente: TesteCF | CerteCF | eCF (Producción)
# ⚠️  NO cambiar a "eCF" hasta tener resolución de la DGII
ECF_ENVIRONMENT=TesteCF

# RNC del emisor (tu empresa, sin guiones)
ECF_RNC_EMISOR=

# Nombre comercial que aparece en los e-CF
ECF_RAZON_SOCIAL=

# Datos del Emisor (obligatorios para certificación DGII)
ECF_DIRECCION_EMISOR=
ECF_MUNICIPIO_EMISOR=
ECF_PROVINCIA_EMISOR=
ECF_TELEFONO_EMISOR=
ECF_CORREO_EMISOR=

# Fecha de Vencimiento de Secuencias autorizadas (formato DD-MM-YYYY)
ECF_FECHA_VENCIMIENTO_SECUENCIA=31-12-2028

# ============================================================
# === Certificado Digital .p12 ================================
# ============================================================
# El proveedor (Digi / Cámara de Comercio) te entregará un
# archivo .p12. Para usarlo:
#   1. Convierte a base64:
#      base64 -i tu-certificado.p12 | tr -d '\n'   (Mac/Linux)
#      certutil -encode cert.p12 cert_b64.txt        (Windows)
#   2. Pega el resultado en ECF_CERTIFICATE_BASE64
#   3. Pon la contraseña del .p12 en ECF_CERTIFICATE_PASSPHRASE
# ============================================================

ECF_CERTIFICATE_BASE64=
ECF_CERTIFICATE_PASSPHRASE=

# Token opcional para proteger /api/sign-xml en producción si ese endpoint sigue habilitado.
SIGN_XML_INTERNAL_TOKEN=

# Contraseñas de bootstrap solo para instalaciones nuevas sin usuarios.
ADMIN_PASSWORD=
SALES_PASSWORD=
INVENTORY_PASSWORD=
